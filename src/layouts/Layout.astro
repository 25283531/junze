---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={Astro.props.description || '钧泽安居 - 河南平顶山一站式家居服务平台'} />
    <meta name="keywords" content={Astro.props.keywords || '平顶山家政服务,平顶山水电维修,平顶山适老化改造,智能家居,房屋检测'} />
    <title>{Astro.props.title || '钧泽安居 - 河南平顶山一站式家居服务平台'}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
    <slot name="head" />
  </head>
  <body>
    <Header />
    <main class="min-h-screen">
      <slot />
    </main>
    <Footer />
  </body>
</html>