            '智能安防：监控摄像头、智能门锁、门窗传感器',
            '智能空调：远程控制、温度调节',
            '智能窗帘：定时开合、语音控制',
            '智能影音：全屋音响、家庭影院',
          ]
        }
      ],
      price_range: '根据系统配置定价，一般智能家居 8000-30000 元',
      process: ['需求分析', '方案设计', '设备采购', '安装调试', '使用培训'],
