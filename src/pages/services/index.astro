---
import Layout from '@/layouts/Layout.astro';
import ServiceCard from '@/components/ServiceCard.astro';

const defaultServices = [
  { id: 1, title: '家政服务', slug: 'jia-zheng-fu-wu', description: '专业家政保洁服务，让您的家焕然一新', price_range: '100-300元/次', icon: 'Home', sort_order: 1 },
  { id: 2, title: '水电维修', slug: 'shui-dian-wei-xiu', description: '专业水电维修安装服务，安全可靠', price_range: '50-100元/次', icon: 'Wrench', sort_order: 2 },
  { id: 3, title: '局部改造', slug: 'ju-bu-gai-zao', description: '房屋局部空间改造，提升居住品质', price_range: '3000-10000元', icon: 'Hammer', sort_order: 3 },
  { id: 4, title: '适老化改造', slug: 'shi-lao-hua-gai-zao', description: '专业适老化改造，关爱老人生活', price_range: '5000-20000元', icon: 'Heart', sort_order: 4 },
  { id: 5, title: '智能家居', slug: 'smart-home', description: '智能家居系统安装，享受智慧生活', price_range: '8000-30000元', icon: 'Cpu', sort_order: 5 },
  { id: 6, title: '房屋检测', slug: 'fang-wu-jian-ce', description: '专业房屋检测，保障居住安全', price_range: '500-2000元', icon: 'Search', sort_order: 6 },
  { id: 7, title: '保洁清洗', slug: 'bao-jie-qing-xi', description: '专业保洁清洗服务，洁净每一天', price_range: '根据服务类型定价', icon: 'Sparkles', sort_order: 7 },
];
const services = defaultServices;
---

<Layout title="服务项目 - 钧泽安居" description="钧泽安居提供家政服务、水电维修、局部改造、适老化改造、智能家居、房屋检测、保洁清洗等七大核心业务" keywords="平顶山家政服务,平顶山水电维修,平顶山适老化改造,智能家居,房屋检测,保洁清洗">
  <section class="bg-gray-50 py-8">
    <div class="max-w-6xl mx-auto px-4">
      <nav class="flex items-center space-x-2 text-gray-500">
        <a href="/" class="hover:text-primary transition-colors">首页</a>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-gray-900 font-medium">服务项目</span>
      </nav>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">七大核心业务</h1>
        <p class="text-gray-500 text-lg">专业团队，用心服务，满足您的各类家居需求</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(service => (
          <ServiceCard key={service.id} service={service} />
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 px-4 bg-gradient-to-br from-primary/5 to-primary/10">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">立即预约服务</h2>
      <p class="text-gray-500 text-lg mb-10">拨打服务热线或添加微信，我们将在24小时内与您联系</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:0375-8888888" class="inline-flex items-center justify-center bg-primary text-white font-semibold px-10 py-4 rounded-xl hover:bg-primary-dark transition-all duration-300 shadow-lg hover:shadow-xl">
          <svg class="w-6 h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          <span class="text-lg">0375-8888888</span>
        </a>
        <a href="#" class="inline-flex items-center justify-center border-2 border-primary text-primary font-semibold px-10 py-4 rounded-xl hover:bg-primary hover:text-white transition-all duration-300">
          添加微信咨询
        </a>
      </div>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', async () => {
      try {
        const response = await fetch('/api/services');
        if (!response.ok) return;
        const services = await response.json();
        if (!services || services.length === 0) return;

        const grid = document.querySelector('.grid.grid-cols-1');
        if (!grid) return;

        const iconMap = {
          'Home': '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>',
          'Wrench': '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>',
          'Hammer': '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>',
          'Heart': '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>',
          'Cpu': '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>',
          'Search': '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>',
          'Sparkles': '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>',
        };

        grid.innerHTML = services.map(service => `
          <div class="bg-white rounded-xl shadow-sm p-6 hover:shadow-md transition-shadow">
            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0 w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center text-blue-600">
                ${iconMap[service.icon] || iconMap['Home']}
              </div>
              <div class="flex-1">
                <h3 class="text-lg font-semibold text-gray-900 mb-2">${service.title}</h3>
                <p class="text-gray-500 text-sm mb-3">${service.description || ''}</p>
                <div class="flex items-center justify-between">
                  <span class="text-blue-600 font-medium text-sm">${service.price_range || ''}</span>
                  <a href="/services/${service.slug}/" class="text-gray-400 hover:text-blue-600 text-sm flex items-center">
                    了解更多
                    <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        `).join('');
      } catch (error) {
        console.error('Failed to load services:', error);
      }
    });
  </script>
</Layout>
