---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="关于我们 - 钧泽安居" description="钧泽安居是河南平顶山本地专业的家居服务平台，提供家政服务、水电维修、适老化改造、智能家居等七大核心业务" keywords="钧泽安居介绍,平顶山家居服务,家政服务公司">
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "钧泽安居",
      "description": "河南平顶山本地专业的家政、水电维修、适老化与智能家居改造服务商",
      "areaServed": ["湛河区", "卫东区", "新华区", "石龙区", "舞钢市", "汝州市", "郏县", "宝丰县", "鲁山县"],
      "telephone": "0375-8888888",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "平顶山",
        "addressRegion": "河南",
        "streetAddress": "平顶山市湛河区建设路东段"
      },
      "service": [
        { "@type": "Service", "name": "家政服务" },
        { "@type": "Service", "name": "水电维修" },
        { "@type": "Service", "name": "局部改造" },
        { "@type": "Service", "name": "适老化改造" },
        { "@type": "Service", "name": "智能家居" },
        { "@type": "Service", "name": "房屋检测" },
        { "@type": "Service", "name": "保洁清洗" }
      ]
    }
  </script>

  <section class="bg-gray-50 py-8">
    <div class="max-w-6xl mx-auto px-4">
      <nav class="flex items-center space-x-2 text-gray-500">
        <a href="/" class="hover:text-primary transition-colors">首页</a>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-gray-900 font-medium">关于我们</span>
      </nav>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">关于钧泽安居</h1>
          <div class="space-y-4">
            <p class="text-gray-600 leading-relaxed text-lg">
              钧泽安居是河南平顶山本地专业的家居服务平台，致力于为平顶山市民提供优质、专业、便捷的家居服务。我们拥有经验丰富的专业服务团队，所有人员均经过严格培训和认证，确保服务质量。
            </p>
            <p class="text-gray-600 leading-relaxed text-lg">
              我们的服务涵盖家政服务、水电维修、局部改造、适老化改造、智能家居、房屋检测、保洁清洗等七大核心业务，能够满足您的各类家居需求。无论是日常保洁、水电维修，还是适老化改造、智能家居安装，我们都能提供专业的解决方案。
            </p>
            <p class="text-gray-600 leading-relaxed text-lg">
              钧泽安居始终坚持"客户至上、服务第一"的理念，以透明的价格、专业的服务、快速的响应，赢得了平顶山市民的信赖和好评。
            </p>
          </div>
          <div class="grid grid-cols-2 gap-4 mt-8">
            <div class="bg-primary/5 rounded-xl p-6 text-center">
              <div class="text-4xl font-bold text-primary mb-2">7</div>
              <div class="text-gray-600">核心业务</div>
            </div>
            <div class="bg-primary/5 rounded-xl p-6 text-center">
              <div class="text-4xl font-bold text-primary mb-2">9</div>
              <div class="text-gray-600">服务区县</div>
            </div>
            <div class="bg-primary/5 rounded-xl p-6 text-center">
              <div class="text-4xl font-bold text-primary mb-2">1000+</div>
              <div class="text-gray-600">服务客户</div>
            </div>
            <div class="bg-primary/5 rounded-xl p-6 text-center">
              <div class="text-4xl font-bold text-primary mb-2">5</div>
              <div class="text-gray-600">年服务经验</div>
            </div>
          </div>
        </div>
        <div class="bg-gradient-to-br from-primary to-primary-dark rounded-2xl p-8 text-white">
          <h2 class="text-2xl font-bold mb-8">联系我们</h2>
          <div class="space-y-6">
            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <div class="text-sm text-white/80 mb-1">服务热线</div>
                <a href="tel:0375-8888888" class="text-xl font-bold text-white hover:underline">0375-8888888</a>
              </div>
            </div>
            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <div class="text-sm text-white/60 mb-1">服务地址</div>
                <div class="text-lg">平顶山市湛河区建设路东段</div>
              </div>
            </div>
            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <div class="text-sm text-white/60 mb-1">微信</div>
                <div class="text-lg">junze-anju</div>
              </div>
            </div>
            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <div class="text-sm text-white/60 mb-1">服务时间</div>
                <div class="text-lg">24小时全天候服务</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-14">服务宗旨</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <div class="text-center">
          <div class="w-20 h-20 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">客户至上</h3>
          <p class="text-gray-500 leading-relaxed">以客户需求为导向，提供优质、专业的服务，让每一位客户都满意</p>
        </div>
        <div class="text-center">
          <div class="w-20 h-20 bg-secondary/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">专业服务</h3>
          <p class="text-gray-500 leading-relaxed">拥有经验丰富的专业团队，所有人员均经过严格培训和认证</p>
        </div>
        <div class="text-center">
          <div class="w-20 h-20 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">透明收费</h3>
          <p class="text-gray-500 leading-relaxed">所有服务价格透明公开，无隐藏收费，服务前提供详细报价</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-14">服务资质</h2>
      <div class="bg-white rounded-2xl shadow-sm p-8 border border-gray-100">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
          <div>
            <h3 class="text-xl font-bold text-gray-900 mb-6">营业执照</h3>
            <div class="bg-gray-50 rounded-xl p-8 text-center">
              <svg class="w-20 h-20 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
              <p class="text-gray-600">营业执照号：XXXXXX</p>
            </div>
          </div>
          <div>
            <h3 class="text-xl font-bold text-gray-900 mb-6">服务认证</h3>
            <div class="space-y-4">
              <div class="flex items-center space-x-4 bg-green-50 rounded-xl p-4">
                <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center">
                  <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <span class="text-gray-700 font-medium">家政服务资质认证</span>
              </div>
              <div class="flex items-center space-x-4 bg-green-50 rounded-xl p-4">
                <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center">
                  <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <span class="text-gray-700 font-medium">水电维修资质认证</span>
              </div>
              <div class="flex items-center space-x-4 bg-green-50 rounded-xl p-4">
                <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center">
                  <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <span class="text-gray-700 font-medium">适老化改造资质认证</span>
              </div>
              <div class="flex items-center space-x-4 bg-green-50 rounded-xl p-4">
                <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center">
                  <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <span class="text-gray-700 font-medium">智能家居安装资质认证</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>