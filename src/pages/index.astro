---
import Layout from '@/layouts/Layout.astro';
import JsonLd from '@/components/JsonLd.astro';
import ServiceCard from '@/components/ServiceCard.astro';

const services = [
  { id: 1, title: '家政服务', slug: 'jia-zheng-fu-wu', description: '专业家政保洁服务，让您的家焕然一新', price_range: '100-300元/次', icon: 'Home', sort_order: 1 },
  { id: 2, title: '水电维修', slug: 'shui-dian-wei-xiu', description: '专业水电维修安装服务，安全可靠', price_range: '50-100元/次', icon: 'Wrench', sort_order: 2 },
  { id: 3, title: '局部改造', slug: 'ju-bu-gai-zao', description: '房屋局部空间改造，提升居住品质', price_range: '3000-10000元', icon: 'Hammer', sort_order: 3 },
  { id: 4, title: '适老化改造', slug: 'shi-lao-hua-gai-zao', description: '专业适老化改造，关爱老人生活', price_range: '5000-20000元', icon: 'Heart', sort_order: 4 },
  { id: 5, title: '智能家居', slug: 'smart-home', description: '智能家居系统安装，享受智慧生活', price_range: '8000-30000元', icon: 'Cpu', sort_order: 5 },
  { id: 6, title: '房屋检测', slug: 'fang-wu-jian-ce', description: '专业房屋检测，保障居住安全', price_range: '500-2000元', icon: 'Search', sort_order: 6 },
  { id: 7, title: '保洁清洗', slug: 'bao-jie-qing-xi', description: '专业保洁清洗服务，洁净每一天', price_range: '根据服务类型定价', icon: 'Sparkles', sort_order: 7 },
];

const serviceAreas = ['湛河区', '卫东区', '新华区', '石龙区', '舞钢市', '汝州市', '郏县', '宝丰县', '鲁山县'];
---

<Layout title="钧泽安居 - 河南平顶山一站式家居服务平台" description="河南平顶山本地专业的家政、水电维修、适老化与智能家居改造服务商，服务区域覆盖湛河区、卫东区、新华区、石龙区、舞钢市、汝州市、郏县、宝丰县、鲁山县" keywords="平顶山家政服务,平顶山水电维修,平顶山适老化改造,智能家居,房屋检测,保洁清洗">
  <JsonLd />

  <section class="relative overflow-hidden bg-gradient-to-br from-primary via-primary-dark to-blue-800 text-white py-24 px-4">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 right-0 w-96 h-96 bg-white rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-white rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>
    </div>
    <div class="relative max-w-6xl mx-auto text-center">
      <div class="inline-flex items-center px-4 py-2 bg-white/10 backdrop-blur-sm rounded-full text-sm font-medium mb-8">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        平顶山本地专业家居服务平台
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 tracking-tight">
        钧泽安居
        <span class="block text-3xl md:text-4xl lg:text-5xl font-normal mt-2 text-white/90">河南平顶山一站式家居服务平台</span>
      </h1>
      <p class="text-lg md:text-xl text-white/80 mb-10 max-w-3xl mx-auto leading-relaxed">
        专业提供家政服务、水电维修、适老化改造、智能家居等七大核心业务，为平顶山市民打造舒适、安全、智慧的家居生活
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/services/jia-zheng-fu-wu" class="inline-flex items-center justify-center bg-white text-primary font-semibold px-8 py-4 rounded-xl hover:bg-gray-100 transition-all duration-300 shadow-lg hover:shadow-xl">
          查看全部服务
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a href="/cases" class="inline-flex items-center justify-center border-2 border-white/30 text-white font-semibold px-8 py-4 rounded-xl hover:bg-white/10 hover:border-white/50 transition-all duration-300">
          查看真实案例
        </a>
      </div>
    </div>
  </section>

  <section class="py-20 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">服务区域</h2>
        <p class="text-gray-500 text-lg">我们的服务覆盖平顶山全市，无论您在哪个区县，都能享受专业服务</p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
        {serviceAreas.map(area => (
          <div key={area} class="group bg-gray-50 rounded-2xl p-6 text-center hover:bg-primary/5 hover:shadow-lg transition-all duration-300 border border-transparent hover:border-primary/10">
            <div class="w-14 h-14 bg-primary/10 group-hover:bg-primary/20 rounded-full flex items-center justify-center mx-auto mb-4 transition-colors duration-300">
              <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <span class="text-gray-900 font-semibold text-lg">{area}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">七大核心业务</h2>
        <p class="text-gray-500 text-lg">专业团队，用心服务，满足您的各类家居需求</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(service => (
          <ServiceCard key={service.id} service={service} />
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">为什么选择我们</h2>
        <p class="text-gray-500 text-lg">我们致力于为平顶山市民提供优质、专业、便捷的家居服务</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center group">
          <div class="w-20 h-20 bg-primary/10 group-hover:bg-primary/20 rounded-full flex items-center justify-center mx-auto mb-6 transition-colors duration-300">
            <svg class="w-10 h-10 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">专业团队</h3>
          <p class="text-gray-500 leading-relaxed">拥有经验丰富的专业服务团队，所有人员均经过严格培训和认证，确保服务质量</p>
        </div>
        <div class="text-center group">
          <div class="w-20 h-20 bg-secondary/10 group-hover:bg-secondary/20 rounded-full flex items-center justify-center mx-auto mb-6 transition-colors duration-300">
            <svg class="w-10 h-10 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">透明收费</h3>
          <p class="text-gray-500 leading-relaxed">所有服务价格透明公开，无隐藏收费，服务前提供详细报价，让您安心消费</p>
        </div>
        <div class="text-center group">
          <div class="w-20 h-20 bg-accent/10 group-hover:bg-accent/20 rounded-full flex items-center justify-center mx-auto mb-6 transition-colors duration-300">
            <svg class="w-10 h-10 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">快速响应</h3>
          <p class="text-gray-500 leading-relaxed">24小时服务热线，快速响应您的需求，及时安排专业人员上门服务</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 px-4 bg-gradient-to-br from-primary/5 to-primary/10">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">立即预约服务</h2>
      <p class="text-gray-500 text-lg mb-10">拨打服务热线或添加微信，我们将在24小时内与您联系</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:0375-8888888" class="inline-flex items-center justify-center bg-primary text-white font-semibold px-10 py-4 rounded-xl hover:bg-primary-dark transition-all duration-300 shadow-lg hover:shadow-xl">
          <svg class="w-6 h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          <span class="text-lg">0375-8888888</span>
        </a>
        <a href="#" class="inline-flex items-center justify-center border-2 border-primary text-primary font-semibold px-10 py-4 rounded-xl hover:bg-primary hover:text-white transition-all duration-300">
          添加微信咨询
        </a>
      </div>
    </div>
  </section>
</Layout>