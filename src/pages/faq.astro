---
import Layout from '@/layouts/Layout.astro';

const defaultFaqs = [
  { id: 1, question: '平顶山钧泽安居的适老化改造包含哪些项目？', answer: '包含地面防滑处理、卫生间安全扶手安装、走廊扶手安装、床边扶手安装、无障碍通道改造、毫米波雷达跌倒检测系统部署、智能感应灯光安装、紧急呼叫系统安装等项目。我们会根据老人的具体情况制定个性化改造方案。', category: '适老化改造' },
  { id: 2, question: '平顶山老房水电改造怎么收费？', answer: '水电改造收费包括上门服务费和材料费用。上门服务费一般 50-100 元，材料费用根据实际使用的管材、电线、开关插座等计算。我们会在施工前提供详细的报价单，确保透明收费。', category: '水电维修' },
  { id: 3, question: '家政保洁服务包含哪些内容？', answer: '我们的家政保洁服务包含日常保洁、深度保洁、新居开荒等。日常保洁包括客厅、卧室、厨房、卫生间的全面清洁；深度保洁增加家电清洗、窗帘清洗、地毯清洗等项目；新居开荒针对新房装修后的彻底清洁。', category: '家政服务' },
  { id: 4, question: '适老化改造需要多长时间？', answer: '适老化改造的时间取决于改造项目的多少和复杂程度。一般简单的适老化改造（如安装扶手、防滑处理）1-2 天即可完成；较复杂的改造（如智能设备安装、无障碍通道改造）可能需要 3-5 天。', category: '适老化改造' },
  { id: 5, question: '智能家居系统可以远程控制吗？', answer: '可以的。我们安装的智能家居系统支持手机 APP 远程控制，您可以随时随地控制家里的灯光、空调、窗帘等设备。同时支持语音控制，让操作更便捷。', category: '智能家居' },
  { id: 6, question: '服务区域覆盖哪些地方？', answer: '我们的服务区域覆盖平顶山全市，包括湛河区、卫东区、新华区、石龙区、舞钢市、汝州市、县、宝丰县、鲁山县。无论您在哪个区县，我们都能提供专业的服务。', category: '服务范围' },
  { id: 7, question: '如何预约服务？', answer: '您可以通过以下方式预约服务：1. 拨打服务热线：0375-8888888；2. 添加微信：junze-anju；3. 填写网站预约表单。我们会在24小时内与您联系，确认服务时间。', category: '预约方式' },
  { id: 8, question: '服务后有质量保证吗？', answer: '有的。我们对所有服务提供质量保证。水电维修提供3个月质保，改造工程提供1年质保，保洁服务提供7天内不满意免费返工。如有任何问题，请及时联系我们。', category: '售后服务' },
];

const defaultCategories = [...new Set(defaultFaqs.map(f => f.category))];
---

<Layout title="常见问题 - 钧泽安居" description="钧泽安居常见问题解答，涵盖适老化改造、水电维修、家政服务、智能家居等服务相关问题" keywords="平顶山家居服务常见问题,适老化改造问答,水电维修问答">
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "平顶山钧泽安居的适老化改造包含哪些项目？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "包含地面防滑处理、卫生间安全扶手安装、走廊扶手安装、床边扶手安装、无障碍通道改造、毫米波雷达跌倒检测系统部署、智能感应灯光安装、紧急呼叫系统安装等项目。"
          }
        },
        {
          "@type": "Question",
          "name": "平顶山老房水电改造怎么收费？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "水电改造收费包括上门服务费和材料费用。上门服务费一般 50-100 元，材料费用根据实际使用的管材、电线、开关插座等计算。"
          }
        },
        {
          "@type": "Question",
          "name": "服务区域覆盖哪些地方？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "我们的服务区域覆盖平顶山全市，包括湛河区、卫东区、新华区、石龙区、舞钢市、汝州市、郏县、宝丰县、鲁山县。"
          }
        }
      ]
    }
  </script>

  <section class="bg-gray-50 py-8">
    <div class="max-w-6xl mx-auto px-4">
      <nav class="flex items-center space-x-2 text-gray-500">
        <a href="/" class="hover:text-primary transition-colors">首页</a>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-gray-900 font-medium">常见问题</span>
      </nav>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-14">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">常见问题解答</h1>
        <p class="text-gray-500 text-lg">以下是客户经常咨询的问题，如果没有找到您需要的答案，请随时联系我们</p>
      </div>

      <div class="flex flex-wrap justify-center gap-3 mb-10" id="faq-filters">
        <button
          class="faq-filter-btn bg-blue-600 text-white px-5 py-2.5 rounded-full font-medium hover:bg-blue-700 transition-all duration-300 shadow-md"
          data-category="all"
        >
          全部
        </button>
        {defaultCategories.map(category => (
          <button
            key={category}
            class="faq-filter-btn bg-white border border-gray-200 text-gray-700 px-5 py-2.5 rounded-full font-medium hover:bg-blue-600 hover:text-white hover:border-blue-600 transition-all duration-300"
            data-category={category}
          >
            {category}
          </button>
        ))}
      </div>

      <div class="space-y-4" id="faq-list">
        {defaultFaqs.map(faq => (
          <div key={faq.id} class="faq-item bg-white rounded-2xl shadow-sm overflow-hidden border border-gray-100 transition-all duration-300 hover:shadow-md" data-category={faq.category}>
            <button
              class="faq-toggle w-full px-6 py-5 flex items-center justify-between text-left hover:bg-gray-50 transition-colors"
            >
              <span class="font-semibold text-gray-900 text-lg">{faq.question}</span>
              <svg class="faq-icon w-5 h-5 text-gray-400 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="faq-answer hidden px-6 pb-5">
              <div class="pl-4 border-l-2 border-primary/30">
                <p class="text-gray-600 leading-relaxed text-lg">{faq.answer}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 px-4 bg-gradient-to-br from-primary/5 to-primary/10">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">没有找到您需要的答案？</h2>
      <p class="text-gray-500 text-lg mb-10">请随时联系我们，我们将为您解答任何问题</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:0375-8888888" class="inline-flex items-center justify-center bg-primary text-white font-semibold px-10 py-4 rounded-xl hover:bg-primary-dark transition-all duration-300 shadow-lg hover:shadow-xl">
          <svg class="w-6 h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          <span class="text-lg">0375-8888888</span>
        </a>
        <a href="#" class="inline-flex items-center justify-center border-2 border-primary text-primary font-semibold px-10 py-4 rounded-xl hover:bg-primary hover:text-white transition-all duration-300">
          添加微信咨询
        </a>
      </div>
    </div>
  </section>

  <script is:inline>
    async function loadFaqData() {
      try {
        const response = await fetch('/api/faq');
        const faqs = await response.json();

        if (faqs && faqs.length > 0) {
          const categories = [...new Set(faqs.map(f => f.category))];
          
          const filtersContainer = document.getElementById('faq-filters');
          const listContainer = document.getElementById('faq-list');

          if (filtersContainer) {
            filtersContainer.innerHTML = `
              <button
                class="faq-filter-btn bg-blue-600 text-white px-5 py-2.5 rounded-full font-medium hover:bg-blue-700 transition-all duration-300 shadow-md"
                data-category="all"
              >
                全部
              </button>
              ${categories.map(category => `
                <button
                  class="faq-filter-btn bg-white border border-gray-200 text-gray-700 px-5 py-2.5 rounded-full font-medium hover:bg-blue-600 hover:text-white hover:border-blue-600 transition-all duration-300"
                  data-category="${category}"
                >
                  ${category}
                </button>
              `).join('')}
            `;
          }

          if (listContainer) {
            listContainer.innerHTML = faqs
              .sort((a, b) => (a.sort_order || 0) - (b.sort_order || 0))
              .map(faq => `
                <div class="faq-item bg-white rounded-2xl shadow-sm overflow-hidden border border-gray-100 transition-all duration-300 hover:shadow-md" data-category="${faq.category}">
                  <button class="faq-toggle w-full px-6 py-5 flex items-center justify-between text-left hover:bg-gray-50 transition-colors">
                    <span class="font-semibold text-gray-900 text-lg">${faq.question}</span>
                    <svg class="faq-icon w-5 h-5 text-gray-400 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </button>
                  <div class="faq-answer hidden px-6 pb-5">
                    <div class="pl-4 border-l-2 border-primary/30">
                      <p class="text-gray-600 leading-relaxed text-lg">${faq.answer}</p>
                    </div>
                  </div>
                </div>
              `).join('');
          }

          initFaqEvents();
        }
      } catch (error) {
        console.error('Failed to load FAQ data:', error);
        initFaqEvents();
      }
    }

    function initFaqEvents() {
      document.querySelectorAll('.faq-toggle').forEach(btn => {
        btn.addEventListener('click', () => {
          const item = btn.closest('.faq-item');
          const answer = item.querySelector('.faq-answer');
          const icon = item.querySelector('.faq-icon');
          answer.classList.toggle('hidden');
          icon.classList.toggle('rotate-180');
        });
      });

      document.querySelectorAll('.faq-filter-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const category = btn.dataset.category;

          document.querySelectorAll('.faq-filter-btn').forEach(b => {
            b.className = 'faq-filter-btn bg-white border border-gray-200 text-gray-700 px-5 py-2.5 rounded-full font-medium hover:bg-blue-600 hover:text-white hover:border-blue-600 transition-all duration-300';
          });
          btn.className = 'faq-filter-btn bg-blue-600 text-white px-5 py-2.5 rounded-full font-medium hover:bg-blue-700 transition-all duration-300 shadow-md';

          document.querySelectorAll('.faq-item').forEach(item => {
            if (category === 'all' || item.dataset.category === category) {
              item.style.display = 'block';
            } else {
              item.style.display = 'none';
            }
          });
        });
      });
    }

    document.addEventListener('DOMContentLoaded', loadFaqData);
  </script>
</Layout>
