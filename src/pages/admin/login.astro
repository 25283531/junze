<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>登录 - 钧泽安居管理后台</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: 'Noto Sans SC', system-ui, -apple-system, sans-serif;
        background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 50%, #0f172a 100%);
        min-height: 100vh;
        display: flex;
        overflow: hidden;
      }
      .sidebar {
        display: none;
        width: 50%;
        position: relative;
        overflow: hidden;
        align-items: center;
        justify-content: center;
        padding: 3rem;
      }
      @media (min-width: 1024px) {
        .sidebar { display: flex; }
      }
      .sidebar-bg-1 {
        position: absolute; top: 5rem; left: 5rem; width: 18rem; height: 18rem;
        background: rgba(59, 130, 246, 0.1); border-radius: 9999px; filter: blur(3rem);
        animation: float 6s ease-in-out infinite;
      }
      .sidebar-bg-2 {
        position: absolute; bottom: 5rem; right: 5rem; width: 24rem; height: 24rem;
        background: rgba(99, 102, 241, 0.1); border-radius: 9999px; filter: blur(3rem);
        animation: float 6s ease-in-out infinite; animation-delay: -3s;
      }
      .sidebar-bg-3 {
        position: absolute; top: 50%; left: 33%; width: 12rem; height: 12rem;
        background: rgba(6, 182, 212, 0.08); border-radius: 9999px; filter: blur(2rem);
        animation: float 6s ease-in-out infinite; animation-delay: -1.5s;
      }
      .sidebar-dots {
        position: absolute; inset: 0; opacity: 0.03;
        background-image: radial-gradient(circle, #fff 1px, transparent 1px);
        background-size: 30px 30px;
      }
      .sidebar-content { position: relative; z-index: 10; max-width: 28rem; animation: fadeIn 0.6s ease-out; }
      .logo-row { display: flex; align-items: center; gap: 1rem; margin-bottom: 3rem; }
      .logo-icon {
        width: 3.5rem; height: 3.5rem; border-radius: 1rem;
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 10px 15px -3px rgba(59, 130, 246, 0.25);
      }
      .logo-icon span { color: #fff; font-weight: 700; font-size: 1.25rem; }
      .logo-text h2 { color: #fff; font-size: 1.5rem; font-weight: 700; }
      .logo-text p { color: rgba(147, 197, 253, 0.7); font-size: 0.875rem; }
      .sidebar-title {
        font-size: 2.25rem; font-weight: 700; color: #fff; line-height: 1.25; margin-bottom: 1.5rem;
      }
      .sidebar-title .gradient-text {
        background: linear-gradient(to right, #60a5fa, #22d3ee);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .sidebar-desc { color: rgba(191, 219, 254, 0.6); font-size: 1.125rem; line-height: 1.625; margin-bottom: 3rem; }
      .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
      .stat-card {
        background: rgba(255,255,255,0.12); backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.18); border-radius: 0.75rem;
        padding: 1rem; text-align: center;
      }
      .stat-card .num { color: #fff; font-size: 1.5rem; font-weight: 700; }
      .stat-card .label { color: rgba(147, 197, 253, 0.6); font-size: 0.75rem; margin-top: 0.25rem; }

      .login-area {
        width: 100%; display: flex; align-items: center; justify-content: center; padding: 1.5rem;
      }
      @media (min-width: 640px) { .login-area { padding: 3rem; } }
      @media (min-width: 1024px) { .login-area { width: 50%; } }
      .login-container { width: 100%; max-width: 24rem; animation: slideUp 0.5s ease-out; }
      .mobile-logo { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 2.5rem; }
      @media (min-width: 1024px) { .mobile-logo { display: none; } }
      .mobile-logo-icon {
        width: 3rem; height: 3rem; border-radius: 0.75rem;
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 10px 15px -3px rgba(59, 130, 246, 0.25);
      }
      .mobile-logo-icon span { color: #fff; font-weight: 700; font-size: 1.125rem; }
      .mobile-logo-text h2 { color: #fff; font-size: 1.25rem; font-weight: 700; }
      .mobile-logo-text p { color: rgba(147, 197, 253, 0.6); font-size: 0.75rem; }
      .login-card {
        background: rgba(255,255,255,0.05); backdrop-filter: blur(24px);
        border: 1px solid rgba(255,255,255,0.1); border-radius: 1rem;
        padding: 2rem; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
      }
      .login-card h3 { color: #fff; font-size: 1.25rem; font-weight: 600; margin-bottom: 0.5rem; }
      .login-card .subtitle { color: rgba(191, 219, 254, 0.5); font-size: 0.875rem; margin-bottom: 2rem; }
      .form-group { margin-bottom: 1.25rem; }
      .form-group label { display: block; font-size: 0.875rem; font-weight: 500; color: rgba(191, 219, 254, 0.7); margin-bottom: 0.5rem; }
      .input-wrapper { position: relative; }
      .input-icon {
        position: absolute; left: 0.875rem; top: 50%; transform: translateY(-50%);
        width: 1.25rem; height: 1.25rem; color: rgba(147, 197, 253, 0.4);
      }
      .input-field {
        width: 100%; padding: 0.75rem 1rem 0.75rem 2.75rem;
        background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
        border-radius: 0.75rem; color: #fff; font-size: 1rem;
        outline: none; transition: all 0.3s ease;
      }
      .input-field::placeholder { color: rgba(191, 219, 254, 0.3); }
      .input-field:focus {
        border-color: rgba(59, 130, 246, 0.5);
        background: rgba(255,255,255,0.08);
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
      }
      .login-btn {
        width: 100%; padding: 0.875rem; border: none; border-radius: 0.75rem;
        background: linear-gradient(to right, #2563eb, #3b82f6);
        color: #fff; font-size: 1rem; font-weight: 600; cursor: pointer;
        box-shadow: 0 10px 15px -3px rgba(59, 130, 246, 0.25);
        transition: all 0.3s ease; margin-top: 0.5rem;
      }
      .login-btn:hover { background: linear-gradient(to right, #3b82f6, #60a5fa); box-shadow: 0 10px 15px -3px rgba(59, 130, 246, 0.4); }
      .login-btn:disabled { opacity: 0.7; cursor: not-allowed; }
      .error-msg { color: #f87171; text-align: center; font-size: 0.875rem; margin-top: 1rem; display: none; }
      .error-msg.show { display: block; }
      .footer-text { text-align: center; color: rgba(191, 219, 254, 0.3); font-size: 0.75rem; margin-top: 2rem; }

      @keyframes fadeIn { 0% { opacity: 0; } 100% { opacity: 1; } }
      @keyframes slideUp { 0% { opacity: 0; transform: translateY(20px); } 100% { opacity: 1; transform: translateY(0); } }
      @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
    </style>
  </head>
  <body>

    <div class="sidebar">
      <div class="sidebar-bg-1"></div>
      <div class="sidebar-bg-2"></div>
      <div class="sidebar-bg-3"></div>
      <div class="sidebar-dots"></div>

      <div class="sidebar-content">
        <div class="logo-row">
          <div class="logo-icon"><span>钧</span></div>
          <div class="logo-text">
            <h2>钧泽安居</h2>
            <p>管理后台系统</p>
          </div>
        </div>

        <h1 class="sidebar-title">
          河南平顶山<br>
          <span class="gradient-text">一站式家居服务平台</span>
        </h1>

        <p class="sidebar-desc">
          专业提供家政服务、水电维修、适老化改造、智能家居等七大核心业务
        </p>

        <div class="stats-grid">
          <div class="stat-card">
            <div class="num">7</div>
            <div class="label">核心业务</div>
          </div>
          <div class="stat-card">
            <div class="num">1000+</div>
            <div class="label">服务客户</div>
          </div>
          <div class="stat-card">
            <div class="num">5年</div>
            <div class="label">服务经验</div>
          </div>
        </div>
      </div>
    </div>

    <div class="login-area">
      <div class="login-container">
        <div class="mobile-logo">
          <div class="mobile-logo-icon"><span>钧</span></div>
          <div class="mobile-logo-text">
            <h2>钧泽安居</h2>
            <p>管理后台系统</p>
          </div>
        </div>

        <div class="login-card">
          <h3>欢迎回来</h3>
          <p class="subtitle">请登录您的管理员账户</p>

          <form id="loginForm">
            <div class="form-group">
              <label>用户名</label>
              <div class="input-wrapper">
                <svg class="input-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
                <input type="text" id="username" class="input-field" placeholder="请输入用户名" />
              </div>
            </div>

            <div class="form-group">
              <label>密码</label>
              <div class="input-wrapper">
                <svg class="input-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                </svg>
                <input type="password" id="password" class="input-field" placeholder="请输入密码" />
              </div>
            </div>

            <button type="submit" id="loginBtn" class="login-btn">登 录</button>
          </form>

          <p id="errorMessage" class="error-msg"></p>
        </div>

        <p class="footer-text">&copy; 2026 钧泽安居 &middot; 河南平顶山</p>
      </div>
    </div>

    <script is:inline>
      (function() {
        console.log('Login script loaded');
        
        function initLoginForm() {
          var form = document.getElementById('loginForm');
          var username = document.getElementById('username');
          var password = document.getElementById('password');
          var errorMessage = document.getElementById('errorMessage');
          var loginBtn = document.getElementById('loginBtn');

          if (!form || !username || !password || !errorMessage || !loginBtn) {
            console.error('Form elements not found');
            return;
          }

          console.log('Login form initialized');

          form.addEventListener('submit', async function(e) {
            e.preventDefault();
            console.log('Form submitted');
            
            var usernameValue = username.value.trim();
            var passwordValue = password.value;

            if (!usernameValue || !passwordValue) {
              errorMessage.textContent = '请输入用户名和密码';
              errorMessage.classList.add('show');
              return;
            }

            errorMessage.classList.remove('show');
            loginBtn.disabled = true;
            loginBtn.textContent = '登录中...';

            try {
              console.log('Sending login request...');
              var response = await fetch('/api/admin/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username: usernameValue, password: passwordValue })
              });

              console.log('Response status:', response.status);
              var data = await response.json();
              console.log('Response data:', data);

              if (data.success) {
                localStorage.setItem('token', data.token);
                window.location.href = '/admin/services';
              } else {
                errorMessage.textContent = data.error || '登录失败，请检查用户名和密码';
                errorMessage.classList.add('show');
                loginBtn.disabled = false;
                loginBtn.textContent = '登 录';
              }
            } catch (error) {
              console.error('Login error:', error);
              errorMessage.textContent = '网络错误：' + error.message;
              errorMessage.classList.add('show');
              loginBtn.disabled = false;
              loginBtn.textContent = '登 录';
            }
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initLoginForm);
        } else {
          initLoginForm();
        }
      })();
    </script>
  </body>
</html>
